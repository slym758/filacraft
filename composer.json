{
    "name": "slym7/filacraft",
    "description": "FilaCraft - A comprehensive Filament panel customization toolkit with theme presets, color palettes, fonts, density, table styles, card styles, and more.",
    "keywords": ["filament", "theme", "customization", "admin-panel", "laravel", "filacraft"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "spatie/laravel-package-tools": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "Slym7\\FilaCraft\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Slym7\\FilaCraft\\FilaCraftServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
