{
    "name": "slym758/filament-filacraft-theme",
    "description": "FilaCraft - A comprehensive Filament panel customization toolkit with theme presets, color palettes, fonts, density, table styles, card styles, and more.",
    "keywords": ["filament", "theme", "customization", "admin-panel", "laravel", "filacraft"],
    "homepage": "https://github.com/slym758/filament-filacraft-themes",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Süleyman Ardıç",
            "email": "slym758@gmail.com",
            "homepage": "https://github.com/slym758"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "Slym758\\FilaCraft\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Slym758\\FilaCraft\\FilaCraftServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
